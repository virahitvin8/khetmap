{
  "appId": "com.khetmap.app",
  "appName": "KhetMap",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#050D05",
    "buildOptions": {
      "keystorePath": null,
      "keystoreAlias": null
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#050D05",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "backgroundColor": "#0A1F0A",
      "style": "DARK",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
