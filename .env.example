# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Copernicus Data Space Ecosystem (Sentinel-2 NDVI WMS)
# Register free at: https://dataspace.copernicus.eu/
# Then create a WMS configuration at: https://shapps.dataspace.copernicus.eu/dashboard/
VITE_COPERNICUS_INSTANCE_ID=your_copernicus_instance_id

# Google Gemini AI (for HARI AI enhanced responses)
# Get free API key at: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here
